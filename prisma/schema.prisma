generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model GameScore {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  gameId     String
  playerName String
  score      Int
  duration   Int?
  meta       String?
  createdAt  DateTime @default(now())

  @@index([gameId, score])
  @@index([playerName])
  @@map("game_scores")
}

model Achievement {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  playerName    String
  achievementId String
  meta          String?
  unlockedAt    DateTime @default(now())

  @@unique([playerName, achievementId])
  @@index([playerName])
  @@map("achievements")
}
